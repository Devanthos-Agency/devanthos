---
import { ArrowRight, FileText, Calendar, User } from 'lucide-react';
import Button from '../ui/Button.astro';

import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
    .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
    .map((post) => ({
        id: post.id,
        title: post.data.title,
        summary: post.data.summary,
        label: post.data.label,
        author: post.data.author,
        published: post.data.published.toLocaleDateString('es-ES', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
        }),
        url: `/blog/${post.id}`,
        image: post.data.heroImage,
    }));
---

<section class="py-32">
    <div class="container mx-auto px-2">
        <div class="mx-auto flex max-w-3xl flex-col items-center gap-4 text-center">
            <span
                class="border-border inline-flex items-center gap-1.5 overflow-hidden rounded-md border px-2 py-0.5 text-xs font-medium whitespace-nowrap">
                <FileText className="size-3" /> Nuestros Blogs
            </span>
            <h2 class="font-cocogoose text-4xl font-normal text-balance">
                Descubre las últimas tendencias
            </h2>
            <p class="text-muted-foreground">
                Explora nuestro blog para encontrar artículos perspicaces, reflexiones personales e
                ideas que inspiran acción sobre los temas que te importan.
            </p>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {
                posts.slice(0, 3).map((post, index) => (
                    <a
                        href={post.url}
                        class="group border-border/40 bg-card relative flex flex-col overflow-hidden rounded-2xl border shadow-sm transition-all duration-500 hover:shadow-xl">
                        {/* Image with category overlay */}
                        <div class="relative overflow-hidden">
                            <img
                                src={post.image}
                                alt={post.title}
                                width="600"
                                height="338"
                                decoding="async"
                                loading="lazy"
                                class="aspect-video w-full object-cover transition-transform duration-700 group-hover:scale-105"
                                transition:name={`img${post.id}`}
                            />
                            {/* Gradient bleed */}
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
                            {/* Category label */}
                            {post.label && (
                                <span class="absolute bottom-3 left-3 rounded-full bg-white/10 px-3 py-1 text-[10px] font-semibold tracking-[0.15em] text-white uppercase backdrop-blur-md">
                                    {post.label}
                                </span>
                            )}
                            {/* Reading index hint */}
                            <span class="pointer-events-none absolute top-3 right-3 text-5xl leading-none font-bold text-black/10 transition-all duration-500 select-none group-hover:text-black/20">
                                {String(index + 1).padStart(2, '0')}
                            </span>
                        </div>

                        {/* Content */}
                        <div class="flex flex-1 flex-col p-5">
                            <h3 class="font-cocogoose text-foreground group-hover:text-primary mb-2 line-clamp-2 text-lg leading-snug font-normal transition-colors duration-300">
                                {post.title}
                            </h3>
                            <p class="text-muted-foreground line-clamp-2 flex-1 text-sm leading-relaxed">
                                {post.summary}
                            </p>

                            {/* Meta row */}
                            <div class="border-border/40 mt-5 flex items-center justify-between border-t pt-4">
                                <div class="flex items-center gap-2.5">
                                    <img
                                        src="/images/team/juan-morales.avif"
                                        alt={`Avatar de ${post.author}`}
                                        width="32"
                                        height="32"
                                        decoding="async"
                                        loading="lazy"
                                        class="ring-border/60 size-7 rounded-full object-cover ring-1"
                                    />
                                    <span class="text-foreground/70 text-xs font-medium">
                                        {post.author}
                                    </span>
                                </div>
                                <div class="text-muted-foreground flex items-center gap-1.5 text-[11px]">
                                    <Calendar className="size-3" />
                                    {post.published}
                                </div>
                            </div>
                        </div>

                        {/* Bottom accent line */}
                        <div class="from-primary to-primary/40 absolute bottom-0 left-0 h-[3px] w-0 bg-gradient-to-r transition-all duration-500 group-hover:w-full" />
                    </a>
                ))
            }
        </div>
        <div class="mt-10 flex justify-center">
            <Button href="/blog">
                Ver todos los blogs <ArrowRight className="ml-2 h-full w-4" />
            </Button>
        </div>
    </div>
</section>
