---
import Button from '../ui/Button.astro';
import { Bot, TrendingUp, Code2, ArrowRight, Brain } from 'lucide-react';

// Datos de servicios organizados en una estructura reutilizable
const services = [
    {
        id: 'desarrollo-web-y-mobile',
        title: 'Desarrollo Web y Móvil',
        description:
            'Nos especializamos en la creación de soluciones digitales modernas, intuitivas y eficientes, tanto en plataformas web como móviles.',
        icon: Code2,
        gradient: 'from-blue-500 to-cyan-500',
        price: 'Desde $250',
        features: ['React & Next.js', 'Apps Móviles', 'APIs REST', 'UI/UX Moderno'],
        href: '/servicios/desarrollo-web-y-mobile',
    },
    {
        id: 'marketing-digital-seo',
        title: 'Marketing Digital y SEO',
        description:
            'Nuestro equipo de marketing digital ofrece estrategias personalizadas para mejorar la visibilidad en línea de tu negocio.',
        icon: TrendingUp,
        gradient: 'from-red-500 to-rose-500',
        price: 'Desde $250/mes',
        features: ['SEO Avanzado', 'Google Ads', 'Social Media', 'Analytics'],
        href: '/servicios/marketing-digital-seo',
    },
    {
        id: 'chatbots-inteligentes',
        title: 'Chatbots para empresas',
        description:
            'Desarrollamos chatbots personalizados que mejoran la atención al cliente y optimizan los procesos internos.',
        icon: Bot,
        gradient: 'from-purple-500 to-indigo-500',
        price: 'Desde $199/mes',
        features: ['IA Avanzada', '24/7 Disponible', 'Multi-plataforma', 'Automatización'],
        href: '/servicios/chatbots-inteligentes',
    },
    {
        id: 'consultoria-empresarial',
        title: 'Consultoría Empresarial',
        description:
            'Impulsamos el crecimiento de tu empresa con estrategias personalizadas, optimización de procesos y transformación digital integral.',
        icon: Brain,
        gradient: 'from-orange-500 to-red-500',
        price: 'Primera consultoría gratis',
        features: [
            'Transformación Digital',
            'Optimización Procesos',
            'Estrategia Empresarial',
            'Consultoría 24/7',
        ],
        href: '/servicios/consultoria-empresarial',
    },
];
---

<section class="relative p-0">
    <div
        class="absolute h-full w-full bg-[url('/images/llleaves.svg')] [mask-image:linear-gradient(to_right,white,transparent,transparent,white)] bg-cover opacity-100 lg:block dark:opacity-50">
    </div>
    <div class="container mx-auto px-2 py-28 md:px-6 md:py-32 lg:px-8">
        <div class="mx-auto flex max-w-7xl flex-col items-center">
            <div class="z-10 mx-auto flex max-w-7xl flex-col items-center gap-6 text-center">
                <span
                    data-slot="badge"
                    class="focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive text-foreground [a&]:hover:bg-accent [a&]:hover:text-accent-foreground hover:bg-secondary/20 inline-flex w-fit shrink-0 items-center justify-center gap-1 overflow-hidden rounded-md border px-2 py-0.5 text-xs font-medium whitespace-nowrap transition-colors focus-visible:ring-[3px] [&>svg]:pointer-events-none [&>svg]:size-3">
                    Nuestros servicios
                </span>
                <div>
                    <h2
                        class="font-cocogoose mb-6 text-4xl font-normal tracking-tight text-pretty md:text-5xl lg:text-6xl">
                        En Devanthos ofrecemos soluciones digitales personalizadas
                    </h2>
                    <p class="text-muted-foreground mx-auto max-w-2xl md:text-lg lg:text-xl">
                        Ofrecemos una amplia gama de servicios diseñados para satisfacer las
                        necesidades de tu negocio, incluyendo desarrollo web, marketing digital y
                        consultoría estratégica.
                    </p>
                </div>
                <div class="mt-6 flex items-center gap-4">
                    <Button href="/contacto" class="group"> Comenzar </Button>
                    <Button href="/servicios" variant="outline" class="group">
                        Ver Todos los Servicios
                    </Button>
                </div>
                <div class="mb-16 grid w-full grid-cols-1 gap-2 md:grid-cols-2 lg:grid-cols-4">
                    {
                        services.map((service, index) => {
                            const IconComponent = service.icon;
                            return (
                                <a
                                    href={service.href}
                                    class="group border-border/50 bg-card/90 hover:border-border/80 relative flex flex-col overflow-hidden rounded-2xl border p-7 text-left backdrop-blur-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl">
                                    {/* Hover tint overlay */}
                                    <div
                                        class={`pointer-events-none absolute inset-0 bg-gradient-to-br ${service.gradient} opacity-0 transition-opacity duration-500 group-hover:opacity-[0.04]`}
                                    />

                                    {/* Ghost number */}
                                    <span class="text-foreground/[0.04] group-hover:text-foreground/[0.07] pointer-events-none absolute -top-4 -right-2 text-[108px] leading-none font-bold transition-all duration-500 select-none">
                                        {String(index + 1).padStart(2, '0')}
                                    </span>

                                    {/* Icon + price */}
                                    <div class="relative mb-7 flex items-start justify-between">
                                        <div
                                            class={`inline-flex rounded-xl bg-gradient-to-br ${service.gradient} p-3.5 shadow-lg shadow-black/10 transition-transform duration-500 group-hover:scale-110`}>
                                            <IconComponent className="h-6 w-6 text-white" />
                                        </div>
                                        <span class="border-border/60 bg-secondary/50 text-muted-foreground mt-1 rounded-full border px-3 py-1 text-[11px] font-medium">
                                            {service.price}
                                        </span>
                                    </div>

                                    {/* Title */}
                                    <h3 class="font-cocogoose text-foreground relative mb-3 text-xl leading-snug font-normal">
                                        {service.title}
                                    </h3>

                                    {/* Description */}
                                    <p class="text-muted-foreground relative mb-6 flex-1 text-sm leading-relaxed">
                                        {service.description}
                                    </p>

                                    {/* Feature pills */}
                                    <div class="relative mb-7 flex flex-wrap gap-1.5">
                                        {service.features.map((feature) => (
                                            <span class="border-border/60 bg-secondary/40 text-muted-foreground inline-flex items-center rounded-full border px-2.5 py-0.5 text-[11px] font-medium">
                                                {feature}
                                            </span>
                                        ))}
                                    </div>

                                    {/* CTA */}
                                    <div class="text-foreground/50 group-hover:text-foreground relative flex items-center gap-2 text-sm font-semibold transition-all duration-300 group-hover:gap-3">
                                        Ver Detalles
                                        <ArrowRight className="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" />
                                    </div>

                                    {/* Bottom accent line */}
                                    <div
                                        class={`absolute bottom-0 left-0 h-[3px] w-0 bg-gradient-to-r ${service.gradient} transition-all duration-500 group-hover:w-full`}
                                    />
                                </a>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </div>
</section>
