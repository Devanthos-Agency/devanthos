---
import Layout from '@/layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { authors } from '@/data/authors';
import { getCollection } from 'astro:content';
import { Users, ArrowRight, BookOpen } from 'lucide-react';
import Button from '@/components/ui/Button.astro';

const posts = await getCollection('blog');
---

<Layout
    title="Autores del Blog | Devanthos"
    description="Conoce al equipo detrás del contenido de Devanthos. Expertos en desarrollo web, marketing digital y tecnología.">
    <section class="relative overflow-hidden px-4 py-24">
        <div
            class="from-primary/50 to-accent/50 absolute inset-0 bg-gradient-to-br via-transparent">
        </div>
        <div class="relative z-10 container mx-auto">
            <div class="mx-auto flex max-w-3xl flex-col items-center gap-6 text-center">
                <Badge
                    className="border-muted bg-muted hover:border-primary flex w-fit items-center gap-1 rounded-full border px-2.5 py-1.5">
                    <Users className="size-4" />
                    Autores
                </Badge>
                <h1
                    class="font-cocogoose text-foreground text-5xl leading-tight [text-shadow:0_0_10px_rgba(255,255,255,0.65)] md:text-6xl">
                    Nuestros <span class="text-primary [text-shadow:0_0_10px_rgba(94,111,182,0.65)]"
                        >Autores</span
                    >
                </h1>
                <p class="text-muted-foreground max-w-2xl text-lg">
                    Conoce al equipo que crea contenido de valor sobre desarrollo web, marketing
                    digital y tecnología.
                </p>
            </div>
        </div>
    </section>

    <section class="py-20">
        <div class="container mx-auto px-4">
            <div class="mx-auto grid max-w-4xl grid-cols-1 gap-8">
                {
                    authors.map((author) => {
                        const authorPosts = posts.filter((p) => p.data.author === author.name);
                        return (
                            <Card className="border-0 shadow-md hover:shadow-lg transition-all duration-300">
                                <CardContent className="p-8">
                                    <div class="flex flex-col items-start gap-6 md:flex-row">
                                        <div class="flex-shrink-0">
                                            <img
                                                src={author.avatar}
                                                alt={`Foto de ${author.name}`}
                                                class="border-primary/20 h-24 w-24 rounded-full border-2 object-cover"
                                                width="96"
                                                height="96"
                                                loading="lazy"
                                            />
                                        </div>
                                        <div class="flex-1">
                                            <h2 class="mb-1 text-2xl font-bold">{author.name}</h2>
                                            <p class="text-primary mb-3 font-medium">
                                                {author.role}
                                            </p>
                                            <p class="text-muted-foreground mb-4">{author.bio}</p>
                                            <div class="flex items-center gap-4">
                                                <span class="text-muted-foreground flex items-center gap-1.5 text-sm">
                                                    <BookOpen className="size-4" />
                                                    {authorPosts.length} artículos
                                                </span>
                                                <Button
                                                    href={`/blog/autor/${author.id}`}
                                                    class="flex h-fit items-center gap-2 rounded-md px-3 py-2 text-sm font-medium">
                                                    Ver artículos
                                                    <ArrowRight className="size-4" />
                                                </Button>
                                            </div>
                                        </div>
                                    </div>
                                </CardContent>
                            </Card>
                        );
                    })
                }
            </div>
        </div>
    </section>
</Layout>
