---
import Layout from '@/layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Mail, Phone, Clock, MessageCircle, Calendar, CheckCircle, Headset } from 'lucide-react';
import Button from '@/components/ui/Button.astro';
import Contact from '@/components/interfaces/Contact';
import Hero from '@/components/interfaces/Hero.astro';
import HeroSubPage from '@/components/interfaces/HeroSubPage.astro';

const contactMethods = [
    {
        icon: Mail,
        title: 'Email',
        description: 'Envíanos un email y te responderemos en 24 horas',
        contact: 'contacto@devanthos.com',
        link: 'mailto:contacto@devanthos.com',
    },
    {
        icon: Phone,
        title: 'Teléfono',
        description: 'Llámanos directamente para consultas urgentes',
        contact: '+54 9 2646-629632',
        link: 'tel:+5492646629632',
    },
    {
        icon: MessageCircle,
        title: 'WhatsApp',
        description: 'Chatea con nosotros por WhatsApp',
        contact: '+54 9 2646-629632',
        link: 'https://wa.me/5492646629632?text=Hola,%20me%20interesa%20la%20consultoria%20gratuita',
    },
    {
        icon: Calendar,
        title: 'Consultoría',
        description: 'Agenda una reunión virtual gratuita',
        contact: 'Calendly',
        link: 'https://calendly.com/devanthos',
    },
];

const officeHours = [
    { day: 'Lunes - Viernes', time: '9:00 AM - 6:00 PM' },
    { day: 'Sábados', time: '10:00 AM - 2:00 PM' },
    { day: 'Domingos', time: 'Cerrado' },
];

const localBusinessSchema = {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Devanthos',
    image: 'https://www.devanthos.com/metadata.jpg',
    url: 'https://www.devanthos.com',
    telephone: '+5492646629632',
    email: 'contacto@devanthos.com',
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'San Juan',
        addressRegion: 'San Juan',
        addressCountry: 'AR',
    },
    openingHoursSpecification: [
        {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
            opens: '09:00',
            closes: '18:00',
        },
        {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: 'Saturday',
            opens: '10:00',
            closes: '14:00',
        },
    ],
    sameAs: ['https://www.instagram.com/devanthos'],
    priceRange: '$$',
};
---

<Layout
    title="Contacto - Consultoría Gratuita | Devanthos"
    description="Ponte en contacto con nuestro equipo. Ofrecemos consultoría gratuita para tu proyecto. Email, teléfono, WhatsApp o agenda una reunión.">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <!-- Hero Section -->
    <HeroSubPage
        badge="Contacto"
        title1="Hablemos de tu "
        title2="proyecto"
        description="Estamos aquí para ayudarte a convertir tus ideas en realidad. Contáctanos y recibe una consultoría gratuita."
        btn1="Solicitar Consultoría Gratuita"
        btn1Icon="MessageCircle"
        btn1href="https://wa.me/5492646629632?text=Hola,%20me%20interesa%20la%20consultoria%20gratuita"
    />

    <!-- Contact Methods -->
    <section class="py-20">
        <div class="container mx-auto px-4">
            <div class="mb-16 text-center">
                <h2 class="mb-4 text-3xl font-bold md:text-4xl">¿Cómo prefieres contactarnos?</h2>
                <p class="text-muted-foreground mx-auto max-w-2xl text-lg">
                    Elige el método que más te convenga. Respondemos rápido en todos los canales.
                </p>
            </div>

            <div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
                {
                    contactMethods.map((method) => (
                        <Card className="border-0 shadow-md hover:shadow-lg transition-all duration-300 group cursor-pointer">
                            <a
                                href={method.link}
                                class="block h-full"
                                aria-label={`${method.title}: ${method.description} - ${method.contact}`}>
                                <span class="sr-only">
                                    Contactar por {method.title}: {method.description}
                                </span>
                                <CardHeader className="text-center pb-4">
                                    <div class="bg-primary/10 group-hover:bg-primary/20 mx-auto mb-4 w-fit rounded-lg p-4 transition-colors">
                                        <method.icon className="w-8 h-8 text-primary" />
                                    </div>
                                    <CardTitle className="text-xl">{method.title}</CardTitle>
                                </CardHeader>
                                <CardContent className="text-center">
                                    <p class="text-muted-foreground mb-4">{method.description}</p>
                                    <p class="text-primary font-semibold transition-all group-hover:underline">
                                        {method.contact}
                                    </p>
                                </CardContent>
                            </a>
                        </Card>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Contact Form -->
    <Contact client:load />

    <!-- Office Hours & Info -->
    <section class="py-20">
        <div class="container mx-auto px-4">
            <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 lg:grid-cols-2">
                <!-- Office Hours -->
                <Card className="border-0 shadow-md">
                    <CardHeader>
                        <div class="mb-4 flex items-center gap-3">
                            <Clock className="text-primary h-6 w-6" />
                            <CardTitle className="text-xl">Horarios de Atención</CardTitle>
                        </div>
                    </CardHeader>
                    <CardContent className="space-y-4">
                        {
                            officeHours.map((schedule) => (
                                <div class="border-border flex items-center justify-between border-b py-2 last:border-b-0">
                                    <span class="font-medium">{schedule.day}</span>
                                    <span class="text-muted-foreground">{schedule.time}</span>
                                </div>
                            ))
                        }
                        <div class="bg-primary/5 mt-6 rounded-lg p-4">
                            <p class="text-muted-foreground text-sm">
                                <strong>Nota:</strong> Para emergencias fuera del horario de oficina,
                                envíanos un WhatsApp y te responderemos lo antes posible.
                            </p>
                        </div>
                    </CardContent>
                </Card>

                <!-- Quick Info -->
                <Card className="border-0 shadow-md">
                    <CardHeader>
                        <CardTitle className="mb-4 text-xl"
                            >¿Qué esperar después de contactarnos?</CardTitle
                        >
                    </CardHeader>
                    <CardContent className="space-y-6">
                        <div class="flex items-start gap-4">
                            <div
                                class="bg-primary/10 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full">
                                <CheckCircle className="text-primary h-4 w-4" />
                            </div>
                            <div>
                                <h4 class="mb-2 font-semibold">Respuesta Rápida</h4>
                                <p class="text-muted-foreground text-sm">
                                    Te contactaremos en menos de 24 horas para agendar una
                                    consultoría gratuita.
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="bg-primary/10 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full">
                                <CheckCircle className="text-primary h-4 w-4" />
                            </div>
                            <div>
                                <h4 class="mb-2 font-semibold">Consultoría Gratuita</h4>
                                <p class="text-muted-foreground text-sm">
                                    Reunión de 30-60 minutos para entender tu proyecto y objetivos.
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="bg-primary/10 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full">
                                <CheckCircle className="text-primary h-4 w-4" />
                            </div>
                            <div>
                                <h4 class="mb-2 font-semibold">Propuesta Detallada</h4>
                                <p class="text-muted-foreground text-sm">
                                    Recibirás una cotización completa con timeline, funcionalidades
                                    y costos.
                                </p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div
                                class="bg-primary/10 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full">
                                <CheckCircle className="text-primary h-4 w-4" />
                            </div>
                            <div>
                                <h4 class="mb-2 font-semibold">Sin Compromiso</h4>
                                <p class="text-muted-foreground text-sm">
                                    No hay obligación de contratar. La consultoría es completamente
                                    gratuita.
                                </p>
                            </div>
                        </div>
                    </CardContent>
                </Card>
            </div>
        </div>
    </section>
</Layout>
