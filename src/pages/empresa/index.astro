---
import Layout from '@/layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import {
    Target,
    Users,
    Heart,
    Code2,
    Lightbulb,
    Mail,
    Github,
    Linkedin,
    Instagram,
    Globe,
    ArrowRight,
    CirclePlay,
    Facebook,
} from 'lucide-react';

import { Behance } from '@/components/icons';
import HeroSubPage from '@/components/interfaces/HeroSubPage.astro';
import Team from '@/components/interfaces/Team.astro';

const values = [
    {
        icon: Code2,
        title: 'Excelencia Técnica',
        description:
            'Nos comprometemos a entregar código de la más alta calidad usando las mejores prácticas y tecnologías modernas.',
    },
    {
        icon: Heart,
        title: 'Pasión por el Desarrollo',
        description:
            'Amamos lo que hacemos y se refleja en cada línea de código que escribimos y cada proyecto que entregamos.',
    },
    {
        icon: Lightbulb,
        title: 'Innovación Constante',
        description:
            'Siempre buscamos nuevas formas de resolver problemas y mejorar la experiencia del usuario.',
    },
    {
        icon: Users,
        title: 'Trabajo en Equipo',
        description:
            'Creemos en la colaboración y el poder del trabajo conjunto para lograr resultados extraordinarios.',
    },
];

const people = [
    {
        id: 'person-1',
        name: 'Juan Morales',
        role: 'Programador Full Stack | CEO',
        description:
            'Me encargo de crear interfaces atractivas y funcionales, optimizando la experiencia del usuario. También lidero el equipo de desarrollo y gestiono proyectos. Mi objetivo es ofrecer soluciones tecnológicas innovadoras que impulsen el crecimiento de nuestros clientes. Además, me apasiona la inteligencia artificial y su aplicación en chatbots para mejorar la atención al cliente y automatizar procesos.',
        avatar: '/images/team/juan-morales.avif',
        socialLinks: [
            {
                name: 'Github',
                url: 'https://github.com/juanmorales1810',
                icon: Github,
            },
            {
                name: 'LinkedIn',
                url: 'https://www.linkedin.com/in/juan-exequiel-morales/',
                icon: Linkedin,
            },
            {
                name: 'Portfolio',
                url: 'https://juan-morales.is-a.dev/',
                icon: Globe,
            },
            {
                name: 'Instagram',
                url: 'https://www.instagram.com/elchiche0_o',
                icon: Instagram,
            },
        ],
    },
    {
        id: 'person-2',
        name: 'Santiago Fernández Salinas',
        role: 'Account Manager | Business Developer | Customer Success Manager',
        description:
            'Encargado de gestionar y fortalecer las relaciones con los clientes, asegurando su satisfacción y acompañándolos en todo el proceso. A través de una comunicación clara y empática, identifico necesidades, resuelvo consultas y brindo soporte personalizado. Además, impulso nuevas oportunidades de negocio y desarrollo estratégico, conectando a los clientes con soluciones a medida que potencian sus resultados',
        avatar: '/images/team/santiago-fernandez.avif',
        socialLinks: [
            {
                name: 'LinkedIn',
                url: 'https://www.linkedin.com/in/santiago-fernandez-salinas/',
                icon: Linkedin,
            },
            {
                name: 'Instagram',
                url: 'https://www.instagram.com/santiagofernandezsalinas/',
                icon: Instagram,
            },
            {
                name: 'Facebook',
                url: 'https://www.facebook.com/share/19HtSBcG5C/',
                icon: Facebook,
            },
        ],
    },
    {
        id: 'person-3',
        name: 'Pablo Valdebenito',
        role: 'Productor Audiovisual & Motion Graphics | Estratega en Marketing Digital y Redes Sociales',
        description:
            'Creatividad en movimiento: produzco, animo y difundo contenidos que atrapan miradas y transmiten mensajes con fuerza conectando a las marcas con su audiencia ideal a través de estrategias digitales efectivas. Mi misión es potenciar la presencia online de las marcas mediante contenido visual impactante y estrategias de marketing digital que generan resultados medibles.',
        avatar: '/images/team/pablo-valdebenito.avif',
        socialLinks: [
            {
                name: 'Behance',
                url: 'https://www.behance.net/pablovaldebe',
                icon: Behance,
            },
            {
                name: 'LinkedIn',
                url: 'https://www.linkedin.com/in/pablo-valdebenito-26173a21b/',
                icon: Linkedin,
            },
            {
                name: 'Instagram',
                url: 'https://www.instagram.com/pavalsig/',
                icon: Instagram,
            },
        ],
    },
    {
        id: 'person-4',
        name: 'Julian Peruzzi',
        role: 'Programador Full Stack | Account Manager',
        description:
            'Soy un apasionado del desarrollo web y móvil, con experiencia en la creación de aplicaciones escalables y eficientes. Me especializo en el desarrollo de soluciones personalizadas que se adaptan a las necesidades de cada cliente. Además, tengo habilidades en la gestión de relaciones con clientes, asegurando una comunicación efectiva y satisfacción continua. Mi objetivo es combinar mis habilidades técnicas y de gestión para ofrecer resultados excepcionales.',
        avatar: '/images/team/julian-peruzzi.avif',
        socialLinks: [
            {
                name: 'Github',
                url: 'https://github.com/julianperuzzi',
                icon: Github,
            },
            {
                name: 'LinkedIn',
                url: 'https://www.linkedin.com/in/julianperuzzi/',
                icon: Linkedin,
            },
            {
                name: 'Instagram',
                url: 'https://www.instagram.com/julianperuzzi/',
                icon: Instagram,
            },
            {
                name: 'Portfolio',
                url: 'https://julianperuzzi.vercel.app/',
                icon: Globe,
            },
        ],
    },
];

const stats = [
    { number: '100+', label: 'Proyectos Completados' },
    { number: '50+', label: 'Clientes Satisfechos' },
    { number: '3', label: 'Años de Experiencia' },
    { number: '24/7', label: 'Soporte Técnico' },
];
---

<Layout
    title="Agencia de Desarrollo Web y Marketing Digital | Devanthos"
    description="Conoce al equipo de Devanthos: expertos en desarrollo web, apps móviles y marketing digital. Nuestra misión, valores y compromiso con tu éxito.">
    <!-- Hero Section -->
    <HeroSubPage
        badge="Sobre Nosotros"
        title1="Construyendo el "
        title2="futuro digital"
        title3=" juntos"
        description="Somos un equipo apasionado de desarrolladores, diseñadores y estrategas digitales comprometidos con transformar ideas en experiencias digitales excepcionales."
        btn1="Nuestra Historia"
        btn1Icon="BookMarked"
        btn2="Ver Video"
    />

    <!-- Mission Section -->
    <section class="mission-section py-24 lg:py-32">
        <div class="container mx-auto px-4">
            <div class="mission-grid">
                <!-- Label lateral vertical -->
                <div class="mission-label-col">
                    <span class="mission-label-vertical">NUESTRA MISIÓN</span>
                </div>

                <!-- Contenido principal -->
                <div class="mission-content">
                    <div class="mission-eyebrow">
                        <span class="mission-line"></span>
                        <span class="mission-tag">Propósito</span>
                    </div>
                    <h2 class="mission-heading">
                        Democratizar<br />
                        <em class="mission-heading-em">el desarrollo</em><br />
                        de software
                    </h2>
                    <p class="mission-body">
                        Creemos que toda empresa, sin importar su tamaño, merece tener acceso a
                        tecnología de clase mundial. Nuestra misión es hacer que el desarrollo de
                        software sea más accesible, eficiente y efectivo.
                    </p>
                    <ul class="mission-list">
                        <li class="mission-list-item">
                            <span class="mission-list-num">01</span>
                            <span>Crear herramientas que simplifiquen el proceso de desarrollo</span
                            >
                        </li>
                        <li class="mission-list-item">
                            <span class="mission-list-num">02</span>
                            <span>Proporcionar soluciones escalables y sostenibles</span>
                        </li>
                        <li class="mission-list-item">
                            <span class="mission-list-num">03</span>
                            <span>Impulsar la innovación en la industria tecnológica</span>
                        </li>
                    </ul>
                </div>

                <!-- Imagen con overlay decorativo -->
                <div class="mission-image-col">
                    <div class="mission-image-frame">
                        <img
                            src="/images/workProcess/Gemini_Generated_Image_15yw9v15yw9v15yw.avif"
                            alt="Equipo trabajando"
                            class="mission-image"
                        />
                        <div class="mission-image-tag">
                            <Target className="mission-image-icon" />
                            <span>Misión</span>
                        </div>
                    </div>
                    <div class="mission-deco-block"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Values Section -->
    <section class="values-section py-24 lg:py-32">
        <div class="container mx-auto px-4">
            <div class="values-header">
                <div class="values-header-left">
                    <span class="values-overline">Filosofía</span>
                    <h2 class="values-heading">Nuestros<br /><strong>Valores</strong></h2>
                </div>
                <p class="values-subtext">
                    Los principios que guían nuestro trabajo y nuestras relaciones con clientes y
                    colaboradores.
                </p>
            </div>

            <div class="values-grid">
                {
                    values.map((value, i) => (
                        <div class="value-card" style={`--delay: ${i * 0.1}s`}>
                            <div class="value-card-inner">
                                <div class="value-icon-wrap">
                                    <value.icon className="value-icon" />
                                </div>
                                <span class="value-num">0{i + 1}</span>
                                <h3 class="value-title">{value.title}</h3>
                                <p class="value-desc">{value.description}</p>
                            </div>
                            <div class="value-card-line" />
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section py-20 lg:py-28">
        <div class="container mx-auto px-4">
            <div class="stats-inner">
                <div class="stats-bg-text" aria-hidden="true">DATA</div>
                <div class="stats-grid">
                    {
                        stats.map((stat, i) => (
                            <div class="stat-item" style={`--delay: ${i * 0.12}s`}>
                                <div class="stat-number">{stat.number}</div>
                                <div class="stat-divider" />
                                <div class="stat-label">{stat.label}</div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <Team />

    <!-- Contact CTA -->
    <section class="cta-section py-24 lg:py-32">
        <div class="container mx-auto px-4">
            <div class="cta-inner">
                <!-- Decorative corner marks -->
                <span class="cta-corner cta-corner--tl"></span>
                <span class="cta-corner cta-corner--tr"></span>
                <span class="cta-corner cta-corner--bl"></span>
                <span class="cta-corner cta-corner--br"></span>

                <div class="cta-content">
                    <p class="cta-overline">¿Tienes un proyecto?</p>
                    <h2 class="cta-heading">
                        Trabajemos<br />
                        <em class="cta-heading-em">juntos</em>
                    </h2>
                    <p class="cta-body">
                        Nos encantaría conocer tu proyecto y ayudarte a convertir tus ideas en
                        realidad. Programa una consultoría gratuita hoy mismo.
                    </p>
                    <div class="cta-actions">
                        <a href="/contacto" class="cta-btn-primary">
                            <Mail className="cta-btn-icon" />
                            Contactar Ahora
                        </a>
                        <a href="/productos" class="cta-btn-secondary">
                            Ver Productos
                            <ArrowRight className="cta-btn-icon" />
                        </a>
                    </div>
                </div>

                <div class="cta-visual" aria-hidden="true">
                    <div class="cta-ring cta-ring--1"></div>
                    <div class="cta-ring cta-ring--2"></div>
                    <div class="cta-ring cta-ring--3"></div>
                    <div class="cta-center-dot"></div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    /* ─────────────────────────────────────────────
   MISSION SECTION
───────────────────────────────────────────── */
    .mission-section {
        position: relative;
        overflow: hidden;
    }

    .mission-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: start;
    }

    @media (min-width: 1024px) {
        .mission-grid {
            grid-template-columns: 2.5rem 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }
    }

    /* Columna de label vertical */
    .mission-label-col {
        display: none;
    }
    @media (min-width: 1024px) {
        .mission-label-col {
            display: flex;
            align-items: center;
            justify-content: center;
        }
    }

    .mission-label-vertical {
        writing-mode: vertical-rl;
        text-orientation: mixed;
        transform: rotate(180deg);
        font-size: 0.65rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--muted-foreground);
        font-weight: 600;
        opacity: 0.5;
    }

    /* Eyebrow */
    .mission-eyebrow {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .mission-line {
        display: block;
        width: 2.5rem;
        height: 2px;
        background: var(--primary);
        flex-shrink: 0;
    }

    .mission-tag {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--primary);
    }

    /* Heading */
    .mission-heading {
        font-family: var(--font-cocogoose), sans-serif;
        font-weight: 500;
        font-size: clamp(2.5rem, 5vw, 4rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
        color: var(--foreground);
        margin-bottom: 1.75rem;
    }

    .mission-heading-em {
        font-style: italic;
        color: var(--primary);
        font-family: var(--font-serif), serif;
        font-weight: 400;
    }

    /* Body */
    .mission-body {
        font-size: 1.05rem;
        line-height: 1.75;
        color: var(--muted-foreground);
        margin-bottom: 2rem;
        max-width: 42ch;
    }

    /* List */
    .mission-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        border-top: 1px solid var(--border);
        padding-top: 1.5rem;
    }

    .mission-list-item {
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        font-size: 0.9rem;
        color: var(--muted-foreground);
        line-height: 1.5;
        animation: fadeSlideUp 0.6s ease both;
        animation-delay: calc(var(--delay, 0s) + 0.3s);
    }

    .mission-list-num {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--primary);
        opacity: 0.7;
        flex-shrink: 0;
        padding-top: 0.15em;
    }

    /* Image column */
    .mission-image-col {
        position: relative;
    }

    .mission-image-frame {
        position: relative;
        border-radius: 0.75rem;
        overflow: hidden;
        box-shadow:
            0 4px 6px -1px oklch(0 0 0 / 0.12),
            0 20px 40px -8px oklch(0 0 0 / 0.18);
    }

    .mission-image {
        width: 100%;
        height: auto;
        display: block;
        aspect-ratio: 4/3;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .mission-image-frame:hover .mission-image {
        transform: scale(1.03);
    }

    .mission-image-tag {
        position: absolute;
        bottom: 1rem;
        left: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: oklch(0 0 0 / 0.55);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid oklch(1 0 0 / 0.12);
        color: white;
        padding: 0.4rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .mission-image-icon {
        width: 0.85rem;
        height: 0.85rem;
        opacity: 0.8;
    }

    /* Decorative block behind image */
    .mission-deco-block {
        position: absolute;
        bottom: -1.25rem;
        right: -1.25rem;
        width: 50%;
        height: 50%;
        border: 2px solid var(--primary);
        border-radius: 0.75rem;
        opacity: 0.2;
        z-index: -1;
        pointer-events: none;
    }

    /* ─────────────────────────────────────────────
   VALUES SECTION
───────────────────────────────────────────── */
    .values-section {
        background:
            radial-gradient(
                ellipse 60% 50% at 80% 20%,
                oklch(0.6 0.12 272 / 0.07) 0%,
                transparent 70%
            ),
            var(--muted);
        position: relative;
        overflow: hidden;
    }

    :global(.dark) .values-section {
        background:
            radial-gradient(
                ellipse 60% 50% at 80% 20%,
                oklch(0.6 0.12 272 / 0.1) 0%,
                transparent 70%
            ),
            var(--card);
    }

    .values-header {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 4rem;
    }

    @media (min-width: 768px) {
        .values-header {
            flex-direction: row;
            align-items: flex-end;
            justify-content: space-between;
        }
    }

    .values-overline {
        display: block;
        font-size: 0.65rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 0.5rem;
    }

    .values-heading {
        font-family: var(--font-cocogoose), sans-serif;
        font-weight: 300;
        font-size: clamp(2rem, 4vw, 3.25rem);
        line-height: 1;
        letter-spacing: -0.02em;
        color: var(--foreground);
    }

    .values-heading strong {
        font-weight: 500;
        color: var(--primary);
    }

    .values-subtext {
        max-width: 38ch;
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--muted-foreground);
    }

    /* Grid */
    .values-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5px;
        border: 1.5px solid var(--border);
        border-radius: 1rem;
        overflow: hidden;
        background: var(--border);
    }

    @media (min-width: 640px) {
        .values-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .values-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    /* Cards */
    .value-card {
        position: relative;
        background: var(--background);
        padding: 2rem 1.75rem 2.5rem;
        overflow: hidden;
        transition: background 0.3s ease;
        animation: fadeSlideUp 0.55s ease both;
        animation-delay: var(--delay, 0s);
    }

    :global(.dark) .value-card {
        background: var(--card);
    }

    .value-card:hover {
        background: var(--card);
        z-index: 1;
    }

    :global(.dark) .value-card:hover {
        background: oklch(0.28 0.04 271 / 1);
    }

    .value-card-line {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 3px;
        background: var(--primary);
        transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .value-card:hover .value-card-line {
        width: 100%;
    }

    .value-card-inner {
        position: relative;
        z-index: 1;
    }

    .value-icon-wrap {
        width: 3rem;
        height: 3rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid var(--border);
        border-radius: 0.625rem;
        margin-bottom: 1.25rem;
        background: var(--background);
        transition:
            border-color 0.3s ease,
            background 0.3s ease;
    }

    .value-card:hover .value-icon-wrap {
        border-color: var(--primary);
        background: oklch(from var(--primary) l c h / 0.08);
    }

    .value-icon {
        width: 1.25rem;
        height: 1.25rem;
        color: var(--primary);
    }

    .value-num {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        color: var(--muted-foreground);
        opacity: 0.5;
        margin-bottom: 0.75rem;
    }

    .value-title {
        font-family: var(--font-cocogoose), sans-serif;
        font-weight: 500;
        font-size: 1rem;
        line-height: 1.2;
        color: var(--foreground);
        margin-bottom: 0.75rem;
        letter-spacing: -0.01em;
    }

    .value-desc {
        font-size: 0.875rem;
        line-height: 1.7;
        color: var(--muted-foreground);
    }

    /* ─────────────────────────────────────────────
   STATS SECTION
───────────────────────────────────────────── */
    .stats-section {
        position: relative;
        overflow: hidden;
    }

    .stats-inner {
        position: relative;
        border-top: 1.5px solid var(--border);
        border-bottom: 1.5px solid var(--border);
        padding: 3.5rem 0;
    }

    .stats-bg-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-family: var(--font-cocogoose), sans-serif;
        font-weight: 500;
        font-size: clamp(5rem, 18vw, 14rem);
        letter-spacing: 0.1em;
        color: var(--foreground);
        opacity: 0.025;
        pointer-events: none;
        user-select: none;
        white-space: nowrap;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
        position: relative;
    }

    @media (min-width: 768px) {
        .stats-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .stat-item {
        text-align: center;
        position: relative;
        animation: fadeSlideUp 0.6s ease both;
        animation-delay: var(--delay, 0s);
    }

    .stat-item::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 1px;
        height: 60%;
        background: var(--border);
    }

    .stat-item:first-child::before {
        display: none;
    }

    @media (max-width: 767px) {
        .stat-item:nth-child(3)::before {
            display: none;
        }
    }

    .stat-number {
        font-family: var(--font-ibm-plex-sans), sans-serif;
        font-weight: 800;
        font-size: clamp(2.5rem, 5vw, 4rem);
        line-height: 1;
        color: var(--primary);
        letter-spacing: -0.04em;
        margin-bottom: 0.5rem;
    }

    .stat-divider {
        width: 2rem;
