---
import Layout from '@/layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import {
    Globe,
    Smartphone,
    ShoppingCart,
    BarChart3,
    Rocket,
    GraduationCap,
    Heart,
    DollarSign,
    Code,
    ArrowRight,
    CheckCircle,
    Zap,
    Users,
    TrendingUp,
    Target,
    Settings,
} from 'lucide-react';

const digitalSolutions = [
    {
        title: 'Web Applications',
        description: 'Aplicaciones web modernas, escalables y seguras para transformar tu negocio',
        icon: Globe,
        features: ['SPA', 'PWA', 'Enterprise Apps', 'APIs REST'],
        timeline: '2-6 meses',
        investment: 'Desde $8,000',
        link: '/soluciones/web-app',
        category: 'Desarrollo Digital',
        highlights: ['React/Vue/Angular', 'Cloud Native', 'Microservicios', 'Seguridad Avanzada'],
    },
    {
        title: 'Apps Móviles',
        description:
            'Aplicaciones nativas e híbridas que conectan con tus usuarios en cualquier lugar',
        icon: Smartphone,
        features: ['iOS & Android', 'React Native', 'Flutter', 'Push Notifications'],
        timeline: '2-4 meses',
        investment: 'Desde $10,000',
        link: '/soluciones/app-movil',
        category: 'Desarrollo Digital',
        highlights: ['App Store Ready', 'Offline Support', 'Biometric Auth', 'Real-time Sync'],
    },
    {
        title: 'E-commerce',
        description: 'Tiendas online completas con gestión de pagos, envíos y analytics avanzados',
        icon: ShoppingCart,
        features: ['Shopify', 'WooCommerce', 'Magento', 'Custom'],
        timeline: '3-8 semanas',
        investment: 'Desde $5,000',
        link: '/soluciones/ecommerce',
        category: 'Desarrollo Digital',
        highlights: ['Conversión Optimizada', 'Multi-payment', 'Inventory Mgmt', 'SEO Ready'],
    },
    {
        title: 'Dashboards & Analytics',
        description: 'Visualización de datos e inteligencia de negocio para decisiones informadas',
        icon: BarChart3,
        features: ['Business Intelligence', 'Real-time Data', 'Custom KPIs', 'Alertas'],
        timeline: '3-6 semanas',
        investment: 'Desde $8,000',
        link: '/soluciones/dashboard',
        category: 'Desarrollo Digital',
        highlights: ['100+ Data Sources', 'Interactive Charts', 'Mobile Ready', 'Export Tools'],
    },
    {
        title: 'Landing Pages',
        description: 'Páginas de alto rendimiento optimizadas para conversión y captación de leads',
        icon: Rocket,
        features: ['CRO Optimized', 'A/B Testing', 'Analytics', 'Mobile First'],
        timeline: '1-3 semanas',
        investment: 'Desde $2,000',
        link: '/soluciones/landing-page',
        category: 'Marketing Digital',
        highlights: ['300% Aumento Promedio', '7 Días Entrega', '25% Conversión', 'SEO Ready'],
    },
    {
        title: 'Portal Personal',
        description:
            'Plataformas personalizadas para gestión de usuarios, perfiles y contenido privado',
        icon: Users,
        features: ['User Management', 'Content CMS', 'Role-based Access', 'Analytics'],
        timeline: '4-8 semanas',
        investment: 'Desde $6,000',
        link: '/soluciones/portal-personal',
        category: 'Desarrollo Digital',
        highlights: ['Multi-tenant', 'Secure Login', 'Custom Workflows', 'API Integration'],
    },
];

const industrySolutions = [
    {
        title: 'Soluciones para Educación',
        description: 'Plataformas e-learning, LMS y herramientas educativas interactivas',
        icon: GraduationCap,
        features: ['LMS', 'Virtual Classrooms', 'Progress Tracking', 'Gamification'],
        industries: ['Universidades', 'Colegios', 'Academias', 'Capacitación Corporativa'],
        link: '/soluciones/educacion',
        category: 'Industria',
        specialFeatures: [
            'SCORM Compliance',
            'Video Streaming',
            'Assessment Tools',
            'Certificates',
        ],
    },
    {
        title: 'Soluciones para Salud',
        description: 'Sistemas médicos, telemedicina y gestión de pacientes',
        icon: Heart,
        features: ['Patient Management', 'Telemedicine', 'EHR Integration', 'Appointments'],
        industries: ['Hospitales', 'Clínicas', 'Consultorios', 'Laboratorios'],
        link: '/soluciones/salud',
        category: 'Industria',
        specialFeatures: [
            'HIPAA Compliance',
            'HL7 Integration',
            'Medical Imaging',
            'Prescriptions',
        ],
    },
    {
        title: 'Soluciones Financieras',
        description: 'Apps bancarias, fintech y sistemas de gestión financiera',
        icon: DollarSign,
        features: ['Banking Apps', 'Payment Processing', 'Investment Tracking', 'Crypto'],
        industries: ['Bancos', 'Fintech', 'Inversiones', 'Seguros'],
        link: '/soluciones/finanzas',
        category: 'Industria',
        specialFeatures: ['PCI Compliance', 'KYC/AML', 'Real-time Trading', 'Risk Management'],
    },
    {
        title: 'Soluciones Tecnológicas',
        description: 'Herramientas para empresas tech, startups y desarrollo de software',
        icon: Code,
        features: ['Developer Tools', 'API Platforms', 'DevOps', 'Monitoring'],
        industries: ['Startups', 'Software Companies', 'IT Services', 'SaaS'],
        link: '/soluciones/tecnologia',
        category: 'Industria',
        specialFeatures: [
            'CI/CD Integration',
            'API Management',
            'Monitoring Tools',
            'Documentation',
        ],
    },
];

const keyBenefits = [
    {
        icon: Zap,
        title: 'Desarrollo Rápido',
        description: 'Entregamos soluciones en tiempo récord sin comprometer la calidad',
        metric: '50% más rápido que el promedio',
    },
    {
        icon: TrendingUp,
        title: 'ROI Comprobado',
        description: 'Nuestras soluciones generan retorno de inversión medible',
        metric: '300% ROI promedio',
    },
    {
        icon: Settings,
        title: '100% Personalizable',
        description: 'Cada solución se adapta perfectamente a tu negocio específico',
        metric: 'Soluciones únicas',
    },
    {
        icon: Target,
        title: 'Optimización Continua',
        description: 'Mejoramos constantemente basándonos en datos y feedback',
        metric: 'A/B testing incluido',
    },
];

const processSteps = [
    {
        step: '1',
        title: 'Consultoría Inicial',
        description: 'Analizamos tu negocio y definimos la estrategia perfecta',
        duration: '1-2 días',
    },
    {
        step: '2',
        title: 'Diseño & Planificación',
        description: 'Creamos prototipos y definimos la arquitectura técnica',
        duration: '3-7 días',
    },
    {
        step: '3',
        title: 'Desarrollo',
        description: 'Construimos tu solución con entregas incrementales',
        duration: '2-12 semanas',
    },
    {
        step: '4',
        title: 'Testing & Launch',
        description: 'Pruebas exhaustivas y lanzamiento con soporte completo',
        duration: '1-2 semanas',
    },
];

const stats = [
    { number: '500+', label: 'Proyectos Entregados' },
    { number: '98%', label: 'Satisfacción Cliente' },
    { number: '300%', label: 'ROI Promedio' },
    { number: '24/7', label: 'Soporte Técnico' },
];
---

<Layout
    title="Soluciones Digitales a Medida por Industria | Devanthos"
    description="Soluciones digitales completas: desarrollo web, apps móviles, e-commerce, dashboards y más. Transformamos tu negocio con tecnología de vanguardia.">
    <main class="min-h-screen">
        <!-- Hero Section -->
        <section class="relative h-dvh overflow-hidden md:h-fit md:py-40">
            <div
                class="from-primary/50 to-accent/50 absolute inset-0 bg-gradient-to-br via-transparent">
            </div>
            <div class="bg-primary/60 absolute -top-40 -right-40 h-80 w-80 rounded-full blur-3xl">
            </div>
            <div class="bg-accent/80 absolute -bottom-40 -left-40 h-80 w-80 rounded-full blur-3xl">
            </div>
            <div class="container mx-auto flex h-full items-center justify-center px-4">
                <div class="mx-auto max-w-6xl">
                    <div class="mb-12 text-center">
                        <Badge className="mb-4">Soluciones Digitales</Badge>
                        <h1 class="mb-6 text-4xl font-bold md:text-6xl">
                            Transformamos Ideas en <span class="text-primary"
                                >Soluciones Digitales</span
                            >
                        </h1>
                        <p class="text-muted-foreground mx-auto mb-8 max-w-3xl text-xl">
                            Desde aplicaciones web hasta plataformas enterprise, desarrollamos
                            soluciones tecnológicas que impulsan el crecimiento de tu negocio con
                            resultados medibles.
                        </p>
                        <div class="flex flex-col justify-center gap-4 sm:flex-row">
                            <a
                                href="/contacto"
                                class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center justify-center rounded-lg px-8 py-3 font-medium transition-colors">
                                <Target className="mr-2 h-4 w-4" />
                                Consultoría Gratuita
                            </a>
                            <a
                                href="#soluciones-digitales"
                                class="border-input hover:bg-accent hover:text-accent-foreground inline-flex items-center justify-center rounded-lg border px-8 py-3 font-medium transition-colors">
                                Ver Todas las Soluciones
                            </a>
                        </div>
                    </div>

                    <!-- Stats -->
                    <div
                        class="border-muted-foreground/20 grid grid-cols-2 gap-8 border-t pt-12 md:grid-cols-4">
                        {
                            stats.map((stat) => (
                                <div class="text-center">
                                    <div class="text-primary mb-2 text-3xl font-bold md:text-4xl">
                                        {stat.number}
                                    </div>
                                    <div class="text-muted-foreground text-sm">{stat.label}</div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- Digital Solutions -->
        <section id="soluciones-digitales" class="py-20">
            <div class="container mx-auto px-4">
                <div class="mb-16 text-center">
                    <h2 class="mb-4 text-3xl font-bold md:text-4xl">Soluciones de Desarrollo</h2>
                    <p class="text-muted-foreground mx-auto max-w-2xl text-lg">
                        Desarrollamos tecnología de vanguardia que transforma la manera en que tu
                        negocio opera y crece.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
                    {
                        digitalSolutions.map((solution) => (
                            <Card className="border-0 shadow-lg hover:shadow-xl transition-all duration-300 group overflow-hidden">
                                <CardHeader className="pb-6">
                                    <div class="mb-4 flex items-center gap-4">
                                        <div class="bg-primary/10 group-hover:bg-primary/20 rounded-lg p-3 transition-colors">
                                            <solution.icon className="w-6 h-6 text-primary" />
                                        </div>
                                        <Badge variant="outline" className="text-xs">
                                            {solution.category}
                                        </Badge>
                                    </div>
                                    <CardTitle className="text-xl mb-2">{solution.title}</CardTitle>
                                    <p class="text-muted-foreground text-sm">
                                        {solution.description}
                                    </p>
                                </CardHeader>
                                <CardContent className="space-y-6">
                                    <div>
                                        <h4 class="mb-3 font-semibold">Tecnologías:</h4>
                                        <div class="flex flex-wrap gap-2">
                                            {solution.features.map((feature) => (
                                                <Badge variant="outline" className="text-xs">
                                                    {feature}
                                                </Badge>
                                            ))}
                                        </div>
                                    </div>

                                    <div>
                                        <h4 class="mb-3 font-semibold">
                                            Características destacadas:
                                        </h4>
                                        <ul class="space-y-2">
                                            {solution.highlights.slice(0, 3).map((highlight) => (
                                                <li class="flex items-center gap-2">
                                                    <CheckCircle className="w-4 h-4 text-green-500 flex-shrink-0" />
                                                    <span class="text-sm">{highlight}</span>
                                                </li>
                                            ))}
                                        </ul>
                                    </div>

                                    <div class="border-border space-y-3 border-t pt-4">
                                        <div class="flex items-center justify-between">
                                            <span class="text-sm font-semibold">Timeline:</span>
                                            <Badge className="bg-blue-100 text-blue-800">
                                                {solution.timeline}
                                            </Badge>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <span class="text-sm font-semibold">Inversión:</span>
                                            <span class="text-primary text-sm font-medium">
                                                {solution.investment}
                                            </span>
                                        </div>
                                    </div>

                                    <a
                                        href={solution.link}
                                        class="bg-primary text-primary-foreground hover:bg-primary/90 group inline-flex w-full items-center justify-center rounded-lg px-4 py-2 font-medium transition-colors">
                                        Conocer Más
                                        <ArrowRight className="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
                                    </a>
                                </CardContent>
                            </Card>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Industry Solutions -->
        <section class="bg-muted/30 py-20">
            <div class="container mx-auto px-4">
                <div class="mb-16 text-center">
                    <h2 class="mb-4 text-3xl font-bold md:text-4xl">Soluciones por Industria</h2>
                    <p class="text-muted-foreground mx-auto max-w-2xl text-lg">
                        Experiencia especializada en sectores clave con soluciones adaptadas a las
                        necesidades específicas de cada industria.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
                    {
                        industrySolutions.map((solution) => (
                            <Card className="border-0 shadow-lg hover:shadow-xl transition-all duration-300 group">
                                <CardHeader className="pb-6">
                                    <div class="mb-4 flex items-center gap-4">
                                        <div class="bg-primary/10 group-hover:bg-primary/20 rounded-lg p-3 transition-colors">
                                            <solution.icon className="w-7 h-7 text-primary" />
                                        </div>
                                        <Badge variant="outline" className="text-xs">
                                            {solution.category}
                                        </Badge>
                                    </div>
                                    <CardTitle className="text-xl mb-2">{solution.title}</CardTitle>
                                    <p class="text-muted-foreground text-sm">
                                        {solution.description}
                                    </p>
                                </CardHeader>
                                <CardContent className="space-y-6">
                                    <div>
                                        <h4 class="mb-3 font-semibold">
                                            Funcionalidades principales:
                                        </h4>
                                        <div class="flex flex-wrap gap-2">
                                            {solution.features.map((feature) => (
                                                <Badge variant="outline" className="text-xs">
                                                    {feature}
                                                </Badge>
                                            ))}
                                        </div>
                                    </div>

                                    <div>
                                        <h4 class="mb-3 font-semibold">Industrias objetivo:</h4>
                                        <div class="grid grid-cols-2 gap-2">
                                            {solution.industries.map((industry) => (
                                                <div class="text-muted-foreground text-sm">
                                                    • {industry}
                                                </div>
                                            ))}
                                        </div>
                                    </div>

                                    <div>
                                        <h4 class="mb-3 font-semibold">
                                            Características especiales:
                                        </h4>
                                        <ul class="space-y-1">
                                            {solution.specialFeatures.slice(0, 3).map((feature) => (
                                                <li class="flex items-center gap-2">
                                                    <CheckCircle className="w-4 h-4 text-green-500 flex-shrink-0" />
                                                    <span class="text-sm">{feature}</span>
                                                </li>
                                            ))}
                                        </ul>
                                    </div>

                                    <a
                                        href={solution.link}
                                        class="bg-primary text-primary-foreground hover:bg-primary/90 group mt-6 inline-flex w-full items-center justify-center rounded-lg px-4 py-2 font-medium transition-colors">
                                        Explorar Solución
                                        <ArrowRight className="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
                                    </a>
                                </CardContent>
                            </Card>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Key Benefits -->
        <section class="py-20">
            <div class="container mx-auto px-4">
                <div class="mb-16 text-center">
                    <h2 class="mb-4 text-3xl font-bold md:text-4xl">¿Por Qué Elegir Devanthos?</h2>
                    <p class="text-muted-foreground mx-auto max-w-2xl text-lg">
                        Más que desarrollo, somos tu socio estratégico en transformación digital con
                        resultados comprobados.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
                    {
                        keyBenefits.map((benefit) => (
                            <Card className="border-0 shadow-md hover:shadow-lg transition-all duration-300 text-center group">
                                <CardHeader className="pb-6">
                                    <div class="bg-primary/10 group-hover:bg-primary/20 mx-auto mb-4 w-fit rounded-lg p-4 transition-colors">
                                        <benefit.icon className="w-8 h-8 text-primary" />
                                    </div>
                                    <CardTitle className="text-lg mb-2">{benefit.title}</CardTitle>
                                    <p class="text-muted-foreground text-sm">
                                        {benefit.description}
                                    </p>
                                </CardHeader>
                                <CardContent>
                                    <Badge className="bg-green-100 text-green-800 font-semibold">
                                        {benefit.metric}
                                    </Badge>
                                </CardContent>
                            </Card>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- Process -->
        <section class="bg-muted/30 py-20">
            <div class="container mx-auto px-4">
                <div class="mb-16 text-center">
                    <h2 class="mb-4 text-3xl font-bold md:text-4xl">Nuestro Proceso</h2>
                    <p class="text-muted-foreground mx-auto max-w-2xl text-lg">
                        Metodología probada que garantiza entregas exitosas en tiempo y presupuesto.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
                    {
                        processSteps.map((step, index) => (
                            <Card className="border-0 shadow-md hover:shadow-lg transition-all duration-300 relative">
                                <CardHeader className="text-center pb-6">
                                    <div class="bg-primary text-primary-foreground mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full text-2xl font-bold">
                                        {step.step}
                                    </div>
                                    <CardTitle className="text-lg mb-2">{step.title}</CardTitle>
                                    <p class="text-muted-foreground text-sm">{step.description}</p>
                                </CardHeader>
                                <CardContent className="text-center">
                                    <Badge variant="outline">{step.duration}</Badge>
                                </CardContent>
                                {index < processSteps.length - 1 && (
                                    <div class="absolute top-1/2 -right-4 hidden -translate-y-1/2 transform lg:block">
                                        <ArrowRight className="w-6 h-6 text-muted-foreground" />
                                    </div>
                                )}
                            </Card>
                        ))
                    }
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="from-primary to-primary/80 text-primary-foreground bg-gradient-to-r py-20">
            <div class="container mx-auto px-4 text-center">
                <div class="mx-auto max-w-4xl">
                    <h2 class="mb-6 text-3xl font-bold md:text-4xl">
                        ¿Listo para Transformar tu Negocio?
                    </h2>
                    <p class="mb-8 text-lg opacity-90">
                        Agenda una consultoría gratuita y descubre cómo nuestras soluciones pueden
                        impulsar tu crecimiento con tecnología de vanguardia.
                    </p>
                    <div class="mb-12 flex flex-col justify-center gap-4 sm:flex-row">
                        <a
                            href="/contacto"
                            class="text-primary inline-flex items-center justify-center rounded-lg bg-white px-8 py-3 font-medium transition-colors hover:bg-gray-100">
                            <Target className="mr-2 h-4 w-4" />
                            Consultoría Gratuita
                        </a>
                        <a
                            href="/productos"
                            class="inline-flex items-center justify-center rounded-lg border border-white/20 px-8 py-3 font-medium transition-colors hover:bg-white/10">
                            Ver Productos
                        </a>
                    </div>

                    <div
                        class="grid grid-cols-2 gap-8 border-t border-white/20 pt-8 md:grid-cols-4">
                        <div class="text-center">
                            <div class="mb-1 text-2xl font-bold">500+</div>
                            <div class="text-sm opacity-75">Proyectos Exitosos</div>
                        </div>
                        <div class="text-center">
                            <div class="mb-1 text-2xl font-bold">98%</div>
                            <div class="text-sm opacity-75">Satisfacción Cliente</div>
                        </div>
                        <div class="text-center">
                            <div class="mb-1 text-2xl font-bold">300%</div>
                            <div class="text-sm opacity-75">ROI Promedio</div>
                        </div>
                        <div class="text-center">
                            <div class="mb-1 text-2xl font-bold">24/7</div>
                            <div class="text-sm opacity-75">Soporte Técnico</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
